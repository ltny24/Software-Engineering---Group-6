# MyUS University Portal – Frontend Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to source control.

# Backend API base URL (proxied locally via package.json "proxy" field)
REACT_APP_API_BASE_URL=http://localhost:8080

# App metadata
REACT_APP_APP_NAME=MyUS University Portal
REACT_APP_VERSION=0.1.0
